#!/bin/bash
# fileview — Open/refresh files as styled HTML in an iTerm2 browser split pane.
# Supports multiple files as tabs within the same pane.
#
# Usage:
#   fileview open <file> [file2] ...  — Add file(s) as tabs, open/reuse browser split
#   fileview close                    — Close the browser split pane + clear all tabs
#   fileview close <file>             — Remove a specific tab
#   fileview list                     — List current tabs

# Derive per-session directory from iTerm session ID
_FV_SESSION_ID="${ITERM_SESSION_ID%%:*}"
_FV_SESSION_DIR="/tmp/fileview/${_FV_SESSION_ID:-default}"
mkdir -p "$_FV_SESSION_DIR"

VIEW_HTML="$_FV_SESSION_DIR/index.html"
VIEW_TEMPLATE="/tmp/fileview/template.html"
TABS_FILE="$_FV_SESSION_DIR/tabs"
ACTIVE_FILE="$_FV_SESSION_DIR/active"
WATCHER_PID="$_FV_SESSION_DIR/watcher.pid"
PANE_SESSION_ID_FILE="$_FV_SESSION_DIR/pane_session_id"
mkdir -p /tmp/fileview

_DYNAMIC_PROFILES_DIR="$HOME/Library/Application Support/iTerm2/DynamicProfiles"
_PROFILE_FILE="$_DYNAMIC_PROFILES_DIR/fileview-${_FV_SESSION_ID:-default}.json"
_PROFILE_NAME="FileView-${_FV_SESSION_ID:-default}"

# Static template with dark/light mode via prefers-color-scheme
cat > "$VIEW_TEMPLATE" << 'TMPL'
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css" id="hljs-dark-theme">
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
html, body { width: 100%; }
body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
