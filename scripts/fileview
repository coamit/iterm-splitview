#!/bin/bash
# fileview — Open/refresh any file as styled HTML in an iTerm2 browser split pane.
#
# Usage:
#   fileview open <file>    — Generate HTML + open browser split
#   fileview refresh <file> — Regenerate HTML from the file
#   fileview close          — Close the browser split pane

# Derive per-session directory from iTerm session ID
_FV_SESSION_ID="${ITERM_SESSION_ID%%:*}"
_FV_SESSION_DIR="/tmp/fileview/${_FV_SESSION_ID:-default}"
mkdir -p "$_FV_SESSION_DIR"

VIEW_HTML="$_FV_SESSION_DIR/index.html"
VIEW_TEMPLATE="/tmp/fileview/template.html"
SOURCE_FILE="$_FV_SESSION_DIR/source"
WATCHER_PID="$_FV_SESSION_DIR/watcher.pid"
PANE_SESSION_ID_FILE="$_FV_SESSION_DIR/pane_session_id"
mkdir -p /tmp/fileview

_DYNAMIC_PROFILES_DIR="$HOME/Library/Application Support/iTerm2/DynamicProfiles"
_PROFILE_FILE="$_DYNAMIC_PROFILES_DIR/fileview-${_FV_SESSION_ID:-default}.json"
_PROFILE_NAME="FileView-${_FV_SESSION_ID:-default}"

# Static template with dark/light mode via prefers-color-scheme
cat > "$VIEW_TEMPLATE" << 'TMPL'
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8" />
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
html, body { width: 100%; }
body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
  padding: 14px 18px;
  font-size: 13px; line-height: 1.5;
  color: #ccd0d4; background: #1f2430;
}
h1, h2, h3 { color: #e8ecf0; border-bottom: 1px solid #353b4a; padding-bottom: 4px; margin-top: 16px; margin-bottom: 8px; }
h1 { font-size: 1.35em; } h2 { font-size: 1.15em; } h3 { font-size: 1em; }
code { background: #2a3040; padding: 1px 5px; border-radius: 3px; font-size: 0.9em; color: #ffcc66; }
pre { background: #2a3040; padding: 10px; border-radius: 5px; overflow-x: auto; margin: 8px 0; }
pre code { padding: 0; background: none; }
blockquote { border-left: 3px solid #87d96c; padding-left: 10px; color: #8a90a0; margin: 6px 0; }
ul, ol { padding-left: 20px; margin: 6px 0; } li { margin-bottom: 2px; }
a { color: #73b8f0; } hr { border: none; border-top: 1px solid #353b4a; margin: 10px 0; }
p { margin: 5px 0; }
strong { color: #e8ecf0; }
table { width: auto; border-collapse: collapse; margin: 10px 0; border: 1px solid #4a5568; table-layout: auto; }
th { background: #2d3748; padding: 8px 12px; text-align: left !important; border: 1px solid #4a5568; font-weight: 600; }
td { padding: 8px 12px; border: 1px solid #4a5568; text-align: left !important; }
tr:hover { background: #2a3040; }

@media (prefers-color-scheme: light) {
  body { color: #24292e; background: #ffffff; }
  h1, h2, h3 { color: #1a1a1a; border-bottom-color: #e1e4e8; }
  code { background: #f0f2f5; color: #c45100; }
  pre { background: #f6f8fa; }
  blockquote { border-left-color: #3fb950; color: #6a737d; }
  a { color: #0366d6; }
  hr { border-top-color: #e1e4e8; }
  strong { color: #1a1a1a; }
  table { border-color: #d0d7de; }
  th { background: #f6f8fa; border-color: #d0d7de; }
  td { border-color: #d0d7de; }
  tr:hover { background: #f6f8fa; }
}
</style>
</head>
<body>
$body$
<script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
<script>
(function(){
  document.querySelectorAll('pre.mermaid').forEach(function(pre){
    var div = document.createElement('div');
    div.className = 'mermaid';
    div.textContent = pre.textContent;
    pre.replaceWith(div);
  });
  mermaid.initialize({
    startOnLoad: true,
    theme: window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'default'
  });
})();
</script>
</body>
</html>
TMPL

generate_html() {
  local src_file="$1"
  if ! pandoc "$src_file" -o "$VIEW_HTML" --template="$VIEW_TEMPLATE"; then
    echo "fileview: pandoc failed to convert $src_file" >&2
    return 1
  fi
  sed -i '' '/<colgroup>/,/<\/colgroup>/d' "$VIEW_HTML" 2>/dev/null
}

stop_watcher() {
  if [ -f "$WATCHER_PID" ]; then
    local pid
    pid=$(cat "$WATCHER_PID")
    kill "$pid" 2>/dev/null
    rm -f "$WATCHER_PID"
  fi
}

_close_fileview_pane() {
  if [ ! -f "$PANE_SESSION_ID_FILE" ]; then
    return 0
  fi
  local pane_id
  pane_id=$(cat "$PANE_SESSION_ID_FILE")
  if [ -z "$pane_id" ]; then
    rm -f "$PANE_SESSION_ID_FILE"
    return 0
  fi
  osascript <<APPLESCRIPT
    tell application "iTerm2"
      repeat with w in windows
        repeat with t in tabs of w
          repeat with s in sessions of t
            if unique ID of s is "$pane_id" then
              tell s to close
              return
            end if
          end repeat
        end repeat
      end repeat
    end tell
APPLESCRIPT
  rm -f "$PANE_SESSION_ID_FILE"
}


_ensure_dynamic_profile() {
  mkdir -p "$_DYNAMIC_PROFILES_DIR"
  cat > "$_PROFILE_FILE" << PROFILE
{
  "Profiles": [{
    "Name": "$_PROFILE_NAME",
    "Guid": "FILEVIEW-$_FV_SESSION_ID",
    "Dynamic Profile Parent Name": "Web Browser",
    "Custom Command": "Browser",
    "Initial URL": "file://$VIEW_HTML"
  }]
}
PROFILE
  # Wait for iTerm to detect the new DynamicProfile
  sleep 0.5
}

start_watcher() {
  local src_file="$1"
  stop_watcher
  echo "$src_file" > "$SOURCE_FILE"
  (
    local last_mtime
    last_mtime=$(stat -f %m "$src_file" 2>/dev/null || echo 0)
    while true; do
      sleep 2
      local cur_mtime
      cur_mtime=$(stat -f %m "$src_file" 2>/dev/null || echo 0)
      if [ "$cur_mtime" != "$last_mtime" ]; then
        last_mtime="$cur_mtime"
        generate_html "$src_file"
      fi
    done
  ) &
  echo $! > "$WATCHER_PID"
}

cmd_open() {
  local src_file="$1"
  if [ -z "$src_file" ]; then
    echo "Usage: fileview open <file>" >&2
    return 1
  fi
  if [ ! -f "$src_file" ]; then
    echo "fileview: file not found: $src_file" >&2
    return 1
  fi

  if ! generate_html "$src_file"; then
    return 1
  fi
  start_watcher "$src_file"

  # Track plan files per-session for fileview-plan shortcut
  case "$src_file" in
    */.claude/plans/*.md) echo "$src_file" > "$_FV_SESSION_DIR/plan" ;;
  esac

  # Check if our tracked browser pane still exists
  local session_uuid="${ITERM_SESSION_ID#*:}"
  local need_split=true
  if [ -f "$PANE_SESSION_ID_FILE" ]; then
    local tracked_pane_id
    tracked_pane_id=$(cat "$PANE_SESSION_ID_FILE")
    if [ -n "$tracked_pane_id" ]; then
      local pane_exists
      pane_exists=$(osascript <<APPLESCRIPT
        tell application "iTerm2"
          repeat with w in windows
            repeat with t in tabs of w
              repeat with s in sessions of t
                if unique ID of s is "$tracked_pane_id" then return "yes"
              end repeat
            end repeat
          end repeat
          return "no"
        end tell
APPLESCRIPT
      )
      if [ "$pane_exists" = "yes" ]; then
        need_split=false
      else
        rm -f "$PANE_SESSION_ID_FILE"
      fi
    fi
  fi

  # Create split only if our pane doesn't exist
  if [ "$need_split" = true ]; then
    _ensure_dynamic_profile
    local new_pane_id
    new_pane_id=$(osascript <<APPLESCRIPT
      tell application "iTerm2"
        repeat with w in windows
          repeat with t in tabs of w
            repeat with s in sessions of t
              if unique ID of s is "$session_uuid" then
                tell s
                  set newSession to (split vertically with profile "$_PROFILE_NAME")
                end tell
                return unique ID of newSession
              end if
            end repeat
          end repeat
        end repeat
      end tell
APPLESCRIPT
    )
    echo "$new_pane_id" > "$PANE_SESSION_ID_FILE"
    # Profile no longer needed — browser has already loaded the URL
    rm -f "$_PROFILE_FILE"
  fi
}

cmd_refresh() {
  local src_file="$1"
  if [ -z "$src_file" ]; then
    echo "Usage: fileview refresh <file>" >&2
    return 1
  fi
  if ! generate_html "$src_file"; then
    return 1
  fi
}

cmd_close() {
  stop_watcher
  rm -f "$SOURCE_FILE"
  rm -f "$_FV_SESSION_DIR/plan"
  _close_fileview_pane
}

case "$1" in
  open)    cmd_open "$2" ;;
  refresh) cmd_refresh "$2" ;;
  close)   cmd_close ;;
  *)       echo "Usage: fileview {open|refresh|close} [file]" >&2; exit 1 ;;
esac
